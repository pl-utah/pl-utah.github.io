{% if alumni and alumni.size > 0 %}
<h2>Ph.D. Alumni</h2>
<ul class="long-list">
{% for person in alumni %}
  {% assign href = person.url | default: person.site %}
  <li>{% if href %}<a href="{{ href }}">{% endif %}{{ person.name }}{% if person.where %} <span>{{ person.where }}</span>{% endif %}{% if href %}</a>{% endif %}</li>
{% endfor %}
</ul>
{% endif %}
